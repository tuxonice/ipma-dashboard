{
    "name": "tuxonice/weather-dashboard",
    "description": "Weather information dashboard for Portugal powered by the IPMA API.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "symfony/cache": "^7.1",
        "symfony/config": "^7.1",
        "symfony/dependency-injection": "^7.1",
        "symfony/dotenv": "^8.0",
        "symfony/event-dispatcher": "^7.1",
        "symfony/http-foundation": "^7.1",
        "symfony/http-kernel": "^7.1",
        "symfony/routing": "^7.1",
        "symfony/translation": "^7.1",
        "symfony/twig-bridge": "^7.1",
        "symfony/yaml": "^7.1",
        "tuxonice/ipma-api": "^v0.6",
        "tuxonice/suncalc-php": "^1.0",
        "twig/intl-extra": "^3.24",
        "twig/twig": "^3.10"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/var-dumper": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
