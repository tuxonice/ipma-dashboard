APP_ENV=dev
APP_DEBUG=1

# Absolute path to the tide harmonic constants JSON file.
# This file is NOT included in the repository for licence reasons.
# Tide panels are silently disabled when this variable is unset or empty.
# See docu/tide-calculation.md for the expected file format.
TIDE_CONSTANTS_FILE=/path/to/tide_constants.json

# Public origin of the site (scheme + host, no trailing slash).
# Used by bin/update-seo-urls.php to stamp public/sitemap.xml and robots.txt.
APP_URL=https://weather-dashboard.example.com