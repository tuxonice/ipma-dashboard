{% extends 'base.html.twig' %}

{% set active = 'bivalves' %}
{% block title %}{{ 'bivalves.title'|trans }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""/>
<style>
    #bivalve-map {
        height: 60vh;
        min-height: 380px;
        border-radius: .5rem;
        z-index: 0;
    }
    .bivalve-swatch {
        display: inline-block;
        width: .75rem;
        height: .75rem;
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,.1);
        margin-right: .25rem;
        vertical-align: -1px;
    }
    .specie-pill {
        display: inline-block;
        padding: .1rem .45rem;
        border-radius: 999px;
        background: var(--bs-tertiary-bg);
        margin: 0 .25rem .25rem 0;
        font-size: .8125rem;
    }
    .specie-pill.closed {
        background: rgba(220, 53, 69, .12);
        color: #842029;
    }
    .specie-pill.open {
        background: rgba(25, 135, 84, .12);
        color: #0f5132;
    }
</style>
{% endblock %}

{% block body %}
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-shell text-primary me-2" aria-hidden="true"></i>{{ 'bivalves.heading'|trans }}
            </h1>
            <p class="text-body-secondary mb-0">
                {{ 'bivalves.subtitle'|trans }}
            </p>
        </div>
    </div>

    {% if error %}
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            {{ 'bivalves.load_error'|trans }}{% if app_debug %}<code>{{ error }}</code>{% endif %}
        </div>
    {% elseif total_zones == 0 %}
        <div class="alert alert-warning" role="alert">
            {{ 'bivalves.no_zones'|trans }}
        </div>
    {% else %}
        <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
            {% for item in legend %}
                <div class="col">
                    <div class="card h-100 border-start border-3"
                         style="border-left-color: {{ item.color }} !important;">
                        <div class="card-body py-3">
                            <div class="small text-body-secondary">
                                <span class="bivalve-swatch" style="background: {{ item.color }};"></span>
                                {{ item.label|trans }}
                            </div>
                            <div class="h4 mb-0">
                                {{ item.count }}
                                <span class="text-body-secondary small fw-normal">{{ 'bivalves.zones'|trans }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div id="bivalve-map" role="img" aria-label="{{ 'bivalves.map_aria'|trans }}" class="mb-4"></div>

        {% for region in regions %}
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-body-secondary">
                    <strong>{{ region.label|trans }}</strong>
                    <span class="text-body-secondary small ms-2">
                        {{ region.rows|length }} {{ (region.rows|length == 1 ? 'bivalves.zone_one' : 'bivalves.zone_many')|trans }}
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col" style="min-width: 8rem;">{{ 'bivalves.col_zone'|trans }}</th>
                                <th scope="col">{{ 'bivalves.col_status'|trans }}</th>
                                <th scope="col">{{ 'bivalves.col_open'|trans }}</th>
                                <th scope="col">{{ 'bivalves.col_closed'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in region.rows %}
                                <tr>
                                    <th scope="row" class="fw-normal">
                                        <div class="fw-semibold">{{ row.name }}</div>
                                        <div class="small text-body-secondary">
                                            {{ row.code }} · {{ row.zone_type }}
                                        </div>
                                    </th>
                                    <td>
                                        <span class="badge text-bg-{{ row.bootstrap }}">{{ row.status_label|trans }}</span>
                                    </td>
                                    <td>
                                        {% if row.open is empty %}
                                            <span class="text-body-secondary small">—</span>
                                        {% else %}
                                            {% for sp in row.open %}
                                                <span class="specie-pill open"
                                                      title="{{ sp.specie_s|default('') }} · classification {{ sp.classification|default('NA') }}">
                                                    {{ sp.specie_c|default(sp.specie_s|default('—')) }}
                                                    {% if sp.classification is defined and sp.classification != '' and sp.classification != 'NA' %}
                                                        <span class="text-body-secondary small">({{ sp.classification }})</span>
                                                    {% endif %}
                                                </span>
                                            {% endfor %}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if row.close is empty %}
                                            <span class="text-body-secondary small">—</span>
                                        {% else %}
                                            {% for sp in row.close %}
                                                <span class="specie-pill closed"
                                                      title="{{ sp.specie_s|default('') }} · classification {{ sp.classification|default('NA') }}">
                                                    {{ sp.specie_c|default(sp.specie_s|default('—')) }}
                                                    {% if sp.classification is defined and sp.classification != '' and sp.classification != 'NA' %}
                                                        <span class="text-body-secondary small">({{ sp.classification }})</span>
                                                    {% endif %}
                                                </span>
                                            {% endfor %}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endfor %}

        <p class="small text-body-secondary mb-0">
            {{ 'bivalves.classification_note'|trans }}
        </p>
    {% endif %}
{% endblock %}

{% block javascripts %}
{% if not error and total_zones > 0 %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
<script id="bivalve-data" type="application/json">{{ features_json|raw }}</script>
<script id="bivalve-i18n" type="application/json">{{ {
    open:   'bivalves.open_prefix'|trans,
    closed: 'bivalves.closed_prefix'|trans,
}|json_encode|raw }}</script>
<script>
    (function () {
        var features = JSON.parse(document.getElementById('bivalve-data').textContent);
        var i18n = JSON.parse(document.getElementById('bivalve-i18n').textContent);

        var map = L.map('bivalve-map', {
            center: [39.5, -8.5],
            zoom: 7,
            scrollWheelZoom: false,
        });

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 18,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        }).addTo(map);

        function escapeHtml(s) {
            return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                return ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' })[c];
            });
        }

        function specieList(arr) {
            if (!arr || arr.length === 0) { return '<span class="text-body-secondary small">—</span>'; }
            return arr.map(function (s) {
                var cls = (s.classification && s.classification !== 'NA')
                    ? ' <span class="text-body-secondary small">(' + escapeHtml(s.classification) + ')</span>'
                    : '';
                var label = s.specie_c || s.specie_s || '—';
                return escapeHtml(label) + cls;
            }).join(', ');
        }

        var bounds = [];
        features.forEach(function (f) {
            var marker = L.circleMarker([f.lat, f.lng], {
                radius: 7,
                weight: 1,
                color: '#ffffff',
                fillColor: f.color,
                fillOpacity: 0.9,
            });
            marker.bindPopup(
                '<strong>' + escapeHtml(f.name) + '</strong>'
                + '<div class="small text-body-secondary">'
                +   escapeHtml(f.code) + ' · ' + escapeHtml(f.zone_type) + ' · ' + escapeHtml(f.region_name)
                + '</div>'
                + '<div class="mt-1"><strong>' + escapeHtml(f.status_label) + '</strong></div>'
                + '<div class="small mt-1"><span class="text-success">' + escapeHtml(i18n.open) + '</span> ' + specieList(f.open) + '</div>'
                + '<div class="small"><span class="text-danger">' + escapeHtml(i18n.closed) + '</span> ' + specieList(f.close) + '</div>'
            );
            marker.addTo(map);
            bounds.push([f.lat, f.lng]);
        });

        if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [20, 20], maxZoom: 9 });
        }
    })();
</script>
{% endif %}
{% endblock %}
