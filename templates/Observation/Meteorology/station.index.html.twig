{% extends 'base.html.twig' %}

{% set active = 'stations' %}
{% block title %}{{ 'station.title'|trans }}{% endblock %}

{% block body %}
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-broadcast-pin text-primary me-2" aria-hidden="true"></i>{{ 'station.heading'|trans }}
            </h1>
            <p class="text-body-secondary mb-0">
                {{ 'station.subtitle'|trans }}
                {% if updated_at %}
                    <span class="ms-1">{{ 'common.updated'|trans }} {{ updated_at|date('Y-m-d H:i', timezone) }}
                    <span class="text-body-tertiary">({{ timezone }})</span></span>
                {% endif %}
            </p>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <div class="btn-group" role="group" aria-label="{{ 'station.heading'|trans }}">
                <a href="{{ path('stations_index') }}" class="btn btn-primary" aria-current="page">
                    <i class="bi bi-table me-1" aria-hidden="true"></i>{{ 'station.table'|trans }}
                </a>
                <a href="{{ path('stations_map') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-map me-1" aria-hidden="true"></i>{{ 'station.map'|trans }}
                </a>
            </div>
            <div style="max-width: 320px;">
                <label for="station-filter" class="visually-hidden">{{ 'common.filter_stations'|trans }}</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                    <input
                        type="search"
                        id="station-filter"
                        class="form-control"
                        placeholder="{{ 'common.filter_by_name'|trans }}"
                        autocomplete="off">
                </div>
            </div>
        </div>
    </div>

    {% if error %}
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            {{ 'station.load_error'|trans }}{% if app_debug %}<code>{{ error }}</code>{% endif %}
        </div>
    {% elseif rows is empty %}
        <div class="alert alert-warning" role="alert">{{ 'station.none_returned'|trans }}</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle bg-body shadow-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">{{ 'station.col_station'|trans }}</th>
                        <th scope="col" class="text-end">{{ 'station.col_temp'|trans }}</th>
                        <th scope="col" class="text-end">{{ 'station.col_humidity'|trans }}</th>
                        <th scope="col" class="text-end">{{ 'station.col_wind'|trans }}</th>
                        <th scope="col" class="text-center">{{ 'station.col_dir'|trans }}</th>
                        <th scope="col" class="text-end">{{ 'station.col_id'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                        <tr data-station-name="{{ row.station.name|lower }}">
                            <td>
                                <a href="{{ path('stations_show', { id: row.station.id }) }}"
                                   class="text-decoration-none fw-semibold">
                                    <i class="bi bi-broadcast text-primary me-1" aria-hidden="true"></i>{{ row.station.name }}
                                </a>
                                <div class="small text-body-secondary">
                                    {{ row.station.latitude|number_format(3) }},
                                    {{ row.station.longitude|number_format(3) }}
                                </div>
                            </td>
                            <td class="text-end">
                                {% if row.temperature_c is not null %}
                                    <span class="fw-bold">{{ row.temperature_c|number_format(1) }} °C</span>
                                {% else %}
                                    <span class="text-body-secondary">—</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% if row.humidity_pct is not null %}
                                    {{ row.humidity_pct|number_format(0) }} %
                                {% else %}
                                    <span class="text-body-secondary">—</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% if row.wind_speed_kmh is not null %}
                                    {{ row.wind_speed_kmh|number_format(1) }} km/h
                                {% else %}
                                    <span class="text-body-secondary">—</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if row.wind_dir_code %}
                                    <span class="badge text-bg-light border" title="{{ row.wind_dir_label|trans }}">
                                        {{ row.wind_dir_code }}
                                    </span>
                                {% else %}
                                    <span class="text-body-secondary">—</span>
                                {% endif %}
                            </td>
                            <td class="text-end small text-body-secondary">{{ row.station.id }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}
<script>
    (function () {
        const input = document.getElementById('station-filter');
        if (!input) return;
        const rows = document.querySelectorAll('[data-station-name]');
        input.addEventListener('input', function () {
            const q = this.value.trim().toLowerCase();
            rows.forEach(row => {
                const match = !q || row.dataset.stationName.includes(q);
                row.classList.toggle('d-none', !match);
            });
        });
    })();
</script>
{% endblock %}
