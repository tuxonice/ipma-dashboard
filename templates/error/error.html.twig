{% extends 'base.html.twig' %}

{% block title %}{{ status }} · IPMA Dashboard{% endblock %}

{% block body %}
    <div class="text-center py-5">
        <div class="display-1 fw-bold text-primary">{{ status }}</div>
        <h1 class="h4 mb-3">{% block heading %}Something went wrong{% endblock %}</h1>
        <p class="text-body-secondary mb-4">
            {% block description %}
                An unexpected error occurred while handling your request.
            {% endblock %}
        </p>
        {% if message is defined and message %}
            <p class="small text-body-secondary">{% if app_debug %}<code>{{ message }}</code>{% endif %}</p>
        {% endif %}
        <a href="{{ path('home') }}" class="btn btn-primary">
            <i class="bi bi-house-door me-1" aria-hidden="true"></i>Back to home
        </a>
    </div>
{% endblock %}
