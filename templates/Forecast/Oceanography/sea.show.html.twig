{% extends 'base.html.twig' %}

{% set active = 'sea' %}
{% block title %}{{ location ? location.name : ('common.unknown'|trans) }} · {{ 'nav.brand'|trans }}{% endblock %}

{% block javascripts %}
    {% if tide_chart_series %}
        <script src="https://cdn.amcharts.com/lib/5/index.js"></script>
        <script src="https://cdn.amcharts.com/lib/5/xy.js"></script>
        <script src="https://cdn.amcharts.com/lib/5/themes/Animated.js"></script>
        <script>
            am5.ready(function () {
                var dataEl = document.getElementById('tide-chart-data');
                if (!dataEl) {
                    return;
                }
                var data = JSON.parse(dataEl.textContent);

                var root = am5.Root.new('tide-chart');
                root.setThemes([am5themes_Animated.new(root)]);

                var chart = root.container.children.push(am5xy.XYChart.new(root, {
                    panX: false,
                    panY: false,
                    wheelX: 'none',
                    wheelY: 'none',
                    layout: root.verticalLayout,
                }));

                var xAxis = chart.xAxes.push(am5xy.DateAxis.new(root, {
                    baseInterval: { timeUnit: 'minute', count: 10 },
                    renderer: am5xy.AxisRendererX.new(root, { minGridDistance: 60 }),
                    tooltipDateFormat: 'dd MMM HH:mm',
                }));
                xAxis.get('dateFormats')['hour'] = 'HH:mm';
                xAxis.get('dateFormats')['day'] = 'dd MMM';
                xAxis.get('periodChangeDateFormats')['hour'] = 'HH:mm';
                xAxis.get('periodChangeDateFormats')['day'] = 'dd MMM';

                var yAxis = chart.yAxes.push(am5xy.ValueAxis.new(root, {
                    renderer: am5xy.AxisRendererY.new(root, {}),
                    numberFormat: "#.0'm'",
                    extraTooltipPrecision: 2,
                }));

                var series = chart.series.push(am5xy.SmoothedXLineSeries.new(root, {
                    name: {{ 'sea.tide'|trans|json_encode|raw }},
                    xAxis: xAxis,
                    yAxis: yAxis,
                    valueXField: 't',
                    valueYField: 'h',
                    stroke: am5.color(0x0d6efd),
                    fill: am5.color(0x0d6efd),
                    tooltip: am5.Tooltip.new(root, {
                        labelText: '{valueY.formatNumber("#.00")} m',
                    }),
                }));
                series.strokes.template.setAll({ strokeWidth: 2 });
                series.fills.template.setAll({ fillOpacity: 0.15, visible: true });

                series.data.setAll(data);

                chart.set('cursor', am5xy.XYCursor.new(root, {
                    behavior: 'none',
                    xAxis: xAxis,
                }));
            });
        </script>
    {% endif %}
{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('home') }}">{{ 'common.home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('sea_index') }}">{{ 'sea.breadcrumb'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">
                {{ location ? location.name : ('common.unknown'|trans) }}
            </li>
        </ol>
    </nav>

    {% if error %}
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            {{ 'sea.could_not_load_location'|trans }}{% if app_debug %}<code>{{ error }}</code>{% endif %}
        </div>
    {% elseif location %}
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h1 class="h3 mb-1">
                    <i class="bi bi-water text-primary me-2" aria-hidden="true"></i>{{ location.name }}
                </h1>
                <p class="text-body-secondary mb-0">
                    {{ 'sea.coordinates_intro'|trans({ '%region%': region_label|trans }) }}
                    {{ location.latitude|number_format(4) }}, {{ location.longitude|number_format(4) }}
                </p>
            </div>
        </div>

        <section aria-labelledby="sea-forecast-heading">
            <div class="d-flex flex-wrap align-items-baseline justify-content-between mb-3 gap-2">
                <h2 id="sea-forecast-heading" class="h4 mb-0">
                    <i class="bi bi-calendar-week me-2 text-primary" aria-hidden="true"></i>{{ 'sea.forecast_heading'|trans }}
                </h2>
                {% if updated_at %}
                    <span class="small text-body-secondary">
                        {{ 'common.updated'|trans }} {{ updated_at|date('Y-m-d H:i', timezone) }}
                        <span class="text-body-secondary">({{ timezone }})</span>
                    </span>
                {% endif %}
            </div>

            {% if forecast_error %}
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
                    {{ 'sea.could_not_load_forecast'|trans }}{% if app_debug %}<code>{{ forecast_error }}</code>{% endif %}
                </div>
            {% elseif days is empty %}
                <div class="alert alert-warning" role="alert">
                    {{ 'sea.no_forecast'|trans }}
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    {% for day in days %}
                        <div class="col">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header bg-primary text-white">
                                    <div class="text-uppercase small">{{ ('common.weekday_short.' ~ day.forecast_date|date('N'))|trans }}</div>
                                    <div class="fw-semibold">{{ day.forecast_date|date('j') }} {{ ('common.month_short.' ~ day.forecast_date|date('n'))|trans }} {{ day.forecast_date|date('Y') }}</div>
                                </div>
                                <div class="card-body">
                                    <dl class="row mb-0 small">
                                        <dt class="col-6">
                                            <i class="bi bi-tsunami text-info me-1" aria-hidden="true"></i>{{ 'sea.wave_height'|trans }}
                                        </dt>
                                        <dd class="col-6 text-end">
                                            <strong>{{ day.wave_high_min|number_format(1) }}–{{ day.wave_high_max|number_format(1) }} m</strong>
                                        </dd>

                                        <dt class="col-6">
                                            <i class="bi bi-arrow-repeat text-secondary me-1" aria-hidden="true"></i>{{ 'sea.period'|trans }}
                                        </dt>
                                        <dd class="col-6 text-end">
                                            {{ day.wave_period_min|number_format(1) }}–{{ day.wave_period_max|number_format(1) }} s
                                        </dd>

                                        <dt class="col-6">
                                            <i class="bi bi-compass text-secondary me-1" aria-hidden="true"></i>{{ 'sea.direction'|trans }}
                                        </dt>
                                        <dd class="col-6 text-end">
                                            <strong>{{ day.wave_dir }}</strong>
                                            <span class="text-body-secondary">· {{ day.wave_dir_label|trans }}</span>
                                        </dd>

                                        <dt class="col-6">
                                            <i class="bi bi-water text-primary me-1" aria-hidden="true"></i>{{ 'sea.total_sea'|trans }}
                                        </dt>
                                        <dd class="col-6 text-end">
                                            {{ day.total_sea_min|number_format(1) }}–{{ day.total_sea_max|number_format(1) }} m
                                        </dd>

                                        <dt class="col-6">
                                            <i class="bi bi-thermometer-half text-danger me-1" aria-hidden="true"></i>{{ 'sea.sst'|trans }}
                                        </dt>
                                        <dd class="col-6 text-end">
                                            {{ day.sst_min|number_format(1) }}–{{ day.sst_max|number_format(1) }} °C
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {% if tide_chart_series %}
                    <figure class="mt-4 mb-2">
                        <figcaption class="d-flex align-items-baseline gap-2 mb-2">
                            <span class="h6 mb-0">
                                <i class="bi bi-droplet-half text-primary me-1" aria-hidden="true"></i>{{ 'sea.tide'|trans }}
                            </span>
                        </figcaption>
                        <div class="card shadow-sm">
                            <div class="card-body py-3">
                                <div id="tide-chart" style="width: 100%; height: 280px;"></div>
                                <script id="tide-chart-data" type="application/json">{{ tide_chart_series|json_encode|raw }}</script>
                            </div>
                        </div>
                    </figure>
                {% endif %}

                {% if tide_extrema_by_day %}
                    <div class="card shadow-sm mt-3 mb-2">
                        <div class="card-body">
                            <h3 class="h6 mb-3">
                                <i class="bi bi-clock-history text-primary me-2" aria-hidden="true"></i>{{ 'sea.tide_extrema_heading'|trans }}
                            </h3>
                            <div class="row row-cols-1 row-cols-md-3 g-3">
                                {% for day_date, extrema in tide_extrema_by_day %}
                                    <div class="col">
                                        <h4 class="small text-uppercase text-body-secondary mb-2">
                                            {{ extrema[0].time|date('l, j F', timezone) }}
                                        </h4>
                                        <ul class="list-unstyled mb-0 small">
                                            {% for ex in extrema %}
                                                <li class="d-flex justify-content-between align-items-baseline border-bottom py-1">
                                                    <span>
                                                        {% if ex.type == 'high' %}
                                                            <i class="bi bi-arrow-up text-primary me-1" aria-hidden="true"></i>{{ 'sea.tide_high'|trans }}
                                                        {% else %}
                                                            <i class="bi bi-arrow-down text-secondary me-1" aria-hidden="true"></i>{{ 'sea.tide_low'|trans }}
                                                        {% endif %}
                                                    </span>
                                                    <span>
                                                        <strong>{{ ex.time|date('H:i', timezone) }}</strong>
                                                        <span class="text-body-secondary ms-2">{{ ex.height|number_format(2) }} m</span>
                                                    </span>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}

                <p class="small text-body-secondary mt-3 mb-0">
                    <i class="bi bi-info-circle me-1" aria-hidden="true"></i>{{ 'sea.tide_disclaimer'|trans }}
                </p>
            {% endif %}
        </section>
    {% endif %}
{% endblock %}
