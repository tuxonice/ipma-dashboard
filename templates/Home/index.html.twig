{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }}{% endblock %}

{% block body %}
    <div class="p-5 mb-4 bg-body rounded-3 shadow-sm">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold">
                <i class="bi bi-cloud-sun-fill text-primary me-2" aria-hidden="true"></i>{{ 'home.title'|trans }}
            </h1>
            <p class="col-md-8 fs-5">
                {{ 'home.intro'|trans|raw }}
            </p>
            <div class="col-md-8 alert alert-info d-flex align-items-start gap-2 mb-0 py-2 px-3">
                <i class="bi bi-info-circle-fill flex-shrink-0 mt-1" aria-hidden="true"></i>
                <small>{{ 'home.disclaimer'|trans }}</small>
            </div>
        </div>
    </div>

    {% if extremes is not null %}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <h2 class="h6 mb-0 fw-semibold text-body-secondary text-uppercase tracking-wide">
                    <i class="bi bi-thermometer-half me-1" aria-hidden="true"></i>{{ 'home.extremes.title'|trans }}
                </h2>
                {% if extremes.updated_at %}
                    <span class="small text-body-tertiary">
                        {{ 'common.updated'|trans }} {{ extremes.updated_at|date('H:i', false) }}
                    </span>
                {% endif %}
            </div>

            {% if extremes.hottest is null and extremes.coldest is null %}
                <p class="text-body-secondary small mb-0">{{ 'home.extremes.no_data'|trans }}</p>
            {% else %}
                <div class="row g-3">
                    {% if extremes.hottest is not null %}
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-3">
                            <span class="display-6 fw-bold text-danger lh-1">
                                {{ extremes.hottest.temperature_c|number_format(1) }}<small class="fs-5 fw-normal"> °C</small>
                            </span>
                            <div>
                                <div class="small fw-semibold text-danger">
                                    <i class="bi bi-arrow-up-circle-fill me-1" aria-hidden="true"></i>{{ 'home.extremes.hottest'|trans }}
                                </div>
                                {% if extremes.hottest.station %}
                                    <a href="{{ path('stations_show', {id: extremes.hottest.station.id}) }}"
                                       class="small text-body-secondary text-decoration-none link-underline-hover">
                                        {{ extremes.hottest.station.name }}
                                    </a>
                                {% endif %}
                                {% if extremes.hottest.at %}
                                    <div class="small text-body-tertiary">{{ extremes.hottest.at|date('H:i', false) }}</div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    {% if extremes.coldest is not null %}
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-3">
                            <span class="display-6 fw-bold text-primary lh-1">
                                {{ extremes.coldest.temperature_c|number_format(1) }}<small class="fs-5 fw-normal"> °C</small>
                            </span>
                            <div>
                                <div class="small fw-semibold text-primary">
                                    <i class="bi bi-arrow-down-circle-fill me-1" aria-hidden="true"></i>{{ 'home.extremes.coldest'|trans }}
                                </div>
                                {% if extremes.coldest.station %}
                                    <a href="{{ path('stations_show', {id: extremes.coldest.station.id}) }}"
                                       class="small text-body-secondary text-decoration-none link-underline-hover">
                                        {{ extremes.coldest.station.name }}
                                    </a>
                                {% endif %}
                                {% if extremes.coldest.at %}
                                    <div class="small text-body-tertiary">{{ extremes.coldest.at|date('H:i', false) }}</div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>

            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if extremes24h is not null %}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <h2 class="h6 mb-0 fw-semibold text-body-secondary text-uppercase tracking-wide">
                    <i class="bi bi-clock-history me-1" aria-hidden="true"></i>{{ 'home.extremes.title_24h'|trans }}
                </h2>
            </div>

            {% if extremes24h.hottest is null and extremes24h.coldest is null %}
                <p class="text-body-secondary small mb-0">{{ 'home.extremes.no_data'|trans }}</p>
            {% else %}
                <div class="row g-3">
                    {% if extremes24h.hottest is not null %}
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-3">
                            <span class="display-6 fw-bold text-danger lh-1">
                                {{ extremes24h.hottest.temperature_c|number_format(1) }}<small class="fs-5 fw-normal"> °C</small>
                            </span>
                            <div>
                                <div class="small fw-semibold text-danger">
                                    <i class="bi bi-arrow-up-circle-fill me-1" aria-hidden="true"></i>{{ 'home.extremes.hottest'|trans }}
                                </div>
                                {% if extremes24h.hottest.station %}
                                    <a href="{{ path('stations_show', {id: extremes24h.hottest.station.id}) }}"
                                       class="small text-body-secondary text-decoration-none link-underline-hover">
                                        {{ extremes24h.hottest.station.name }}
                                    </a>
                                {% endif %}
                                <div class="small text-body-tertiary">{{ extremes24h.hottest.at|date('H:i', false) }}</div>
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    {% if extremes24h.coldest is not null %}
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-3">
                            <span class="display-6 fw-bold text-primary lh-1">
                                {{ extremes24h.coldest.temperature_c|number_format(1) }}<small class="fs-5 fw-normal"> °C</small>
                            </span>
                            <div>
                                <div class="small fw-semibold text-primary">
                                    <i class="bi bi-arrow-down-circle-fill me-1" aria-hidden="true"></i>{{ 'home.extremes.coldest'|trans }}
                                </div>
                                {% if extremes24h.coldest.station %}
                                    <a href="{{ path('stations_show', {id: extremes24h.coldest.station.id}) }}"
                                       class="small text-body-secondary text-decoration-none link-underline-hover">
                                        {{ extremes24h.coldest.station.name }}
                                    </a>
                                {% endif %}
                                <div class="small text-body-tertiary">{{ extremes24h.coldest.at|date('H:i', false) }}</div>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>

            {% endif %}
        </div>
    </div>
    {% endif %}

    <div class="row g-4">
        <div class="col-md-4">
            <a href="{{ path('locations_index') }}"
               class="card h-100 text-decoration-none text-body">
                <div class="card-body">
                    <h2 class="h5 card-title"><i class="bi bi-geo-alt me-2" aria-hidden="true"></i>{{ 'home.cards.locations_title'|trans }}</h2>
                    <p class="card-text text-body-secondary">
                        {{ 'home.cards.locations_body'|trans }}
                    </p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('warnings_index') }}"
               class="card h-100 text-decoration-none text-body">
                <div class="card-body">
                    <h2 class="h5 card-title"><i class="bi bi-exclamation-triangle me-2" aria-hidden="true"></i>{{ 'home.cards.warnings_title'|trans }}</h2>
                    <p class="card-text text-body-secondary">
                        {{ 'home.cards.warnings_body'|trans }}
                    </p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('sea_index') }}"
               class="card h-100 text-decoration-none text-body">
                <div class="card-body">
                    <h2 class="h5 card-title"><i class="bi bi-water me-2" aria-hidden="true"></i>{{ 'home.cards.sea_title'|trans }}</h2>
                    <p class="card-text text-body-secondary">
                        {{ 'home.cards.sea_body'|trans }}
                    </p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('stations_index') }}"
               class="card h-100 text-decoration-none text-body">
                <div class="card-body">
                    <h2 class="h5 card-title"><i class="bi bi-broadcast-pin me-2" aria-hidden="true"></i>{{ 'home.cards.stations_title'|trans }}</h2>
                    <p class="card-text text-body-secondary">
                        {{ 'home.cards.stations_body'|trans }}
                    </p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('fire_risk_index') }}"
               class="card h-100 text-decoration-none text-body">
                <div class="card-body">
                    <h2 class="h5 card-title"><i class="bi bi-fire text-danger me-2" aria-hidden="true"></i>{{ 'home.cards.fire_risk_title'|trans }}</h2>
                    <p class="card-text text-body-secondary">
                        {{ 'home.cards.fire_risk_body'|trans }}
                    </p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('climate_index') }}"
               class="card h-100 text-decoration-none text-body">
                <div class="card-body">
                    <h2 class="h5 card-title"><i class="bi bi-thermometer-half me-2" aria-hidden="true"></i>{{ 'home.cards.climate_title'|trans }}</h2>
                    <p class="card-text text-body-secondary">
                        {{ 'home.cards.climate_body'|trans }}
                    </p>
                </div>
            </a>
        </div>
    </div>
{% endblock %}
