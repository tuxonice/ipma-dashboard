{% extends 'base.html.twig' %}

{% set active = 'locations' %}
{% block title %}{{ location ? location.name : ('common.unknown'|trans) }} · {{ 'nav.brand'|trans }}{% endblock %}

{% block body %}
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <nav aria-label="breadcrumb" class="mb-0">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="{{ path('home') }}">{{ 'common.home'|trans }}</a></li>
                <li class="breadcrumb-item"><a href="{{ path('locations_index') }}">{{ 'location.breadcrumb'|trans }}</a></li>
                <li class="breadcrumb-item active" aria-current="page">
                    {{ location ? location.name : ('common.unknown'|trans) }}
                </li>
            </ol>
        </nav>
    </div>

    {% if error %}
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            {{ 'location.could_not_load_location'|trans }}{% if app_debug %}<code>{{ error }}</code>{% endif %}
        </div>
    {% elseif location %}
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h1 class="h3 mb-1">
                    <i class="bi bi-geo-alt-fill text-primary me-2" aria-hidden="true"></i>{{ location.name }}
                </h1>
                <p class="text-body-secondary mb-3">{{ region_label|trans }}</p>
                <dl class="row mb-0">
                    <dt class="col-sm-4 col-md-3">{{ 'location.global_id'|trans }}</dt>
                    <dd class="col-sm-8 col-md-9"><code>{{ location.globalIdLocal }}</code></dd>

{#                    <dt class="col-sm-4 col-md-3">{{ 'location.district_id'|trans }}</dt>#}
{#                    <dd class="col-sm-8 col-md-9">{{ location.idDistrict }}</dd>#}

{#                    <dt class="col-sm-4 col-md-3">{{ 'location.municipality_id'|trans }}</dt>#}
{#                    <dd class="col-sm-8 col-md-9">{{ location.idMunicipality }}</dd>#}

                    <dt class="col-sm-4 col-md-3">{{ 'location.warning_area'|trans }}</dt>
                    <dd class="col-sm-8 col-md-9"><code>{{ location.idWarningArea }}</code></dd>

                    <dt class="col-sm-4 col-md-3">{{ 'location.coordinates'|trans }}</dt>
                    <dd class="col-sm-8 col-md-9">
                        {{ location.latitude|number_format(5) }}, {{ location.longitude|number_format(5) }}
                        <a
                            class="ms-2 small"
                            target="_blank"
                            rel="noopener"
                            href="https://www.openstreetmap.org/?mlat={{ location.latitude }}&mlon={{ location.longitude }}#map=10/{{ location.latitude }}/{{ location.longitude }}">
                            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> {{ 'location.map'|trans }}
                        </a>
                    </dd>

                </dl>
            </div>
        </div>

        {% include 'Forecast/Warnings/warning._banner.html.twig' %}

        <section aria-labelledby="forecast-heading">
            <div class="d-flex flex-wrap align-items-baseline justify-content-between mb-3 gap-2">
                <h2 id="forecast-heading" class="h4 mb-0">
                    <i class="bi bi-calendar-week me-2 text-primary" aria-hidden="true"></i>{{ 'location.daily_forecast'|trans }}
                </h2>
                {% if forecast_updated_at %}
                    <span class="small text-body-secondary">
                        {{ 'common.updated'|trans }} {{ forecast_updated_at|date('Y-m-d H:i', timezone) }}
                        <span class="text-body-tertiary">({{ timezone }})</span>
                    </span>
                {% endif %}
            </div>

            {% if forecast_error %}
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
                    {{ 'location.could_not_load_forecast'|trans }}{% if app_debug %}<code>{{ forecast_error }}</code>{% endif %}
                </div>
            {% elseif forecast_days is empty %}
                <div class="alert alert-warning" role="alert">
                    {{ 'location.no_forecast_available'|trans }}
                </div>
            {% else %}
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-5 g-3">
                    {% for day in forecast_days %}
                        <div class="col">
                            <div class="card h-100 text-center shadow-sm">
                                <div class="card-body">
                                    <div class="text-body-secondary small text-uppercase">
                                        {{ ('common.weekday_short.' ~ day.date|date('N'))|trans }}
                                    </div>
                                    <div class="fw-semibold mb-2">
                                        {{ day.date|date('j') }} {{ ('common.month_short.' ~ day.date|date('n'))|trans }}
                                    </div>

                                    <i class="bi {{ day.weather_type_icon }} display-5 text-primary d-block mb-1"
                                       aria-hidden="true"
                                       title="{{ day.weather_type_label|trans }}"></i>
                                    <div class="small text-body-secondary mb-3">
                                        {{ day.weather_type_label|trans }}
                                    </div>

                                    <div class="d-flex justify-content-center align-items-baseline gap-2 mb-2">
                                        <span class="fs-4 fw-bold text-danger">
                                            {{ day.max_temp|number_format(0) }}°
                                        </span>
                                        <span class="fs-6 text-body-secondary">
                                            {{ day.min_temp|number_format(0) }}°
                                        </span>
                                    </div>

                                    <ul class="list-unstyled small mb-0 text-start">
                                        <li>
                                            <i class="bi bi-droplet-half me-1 text-info" aria-hidden="true"></i>
                                            {{ 'location.rain'|trans }}: <strong>{{ day.rainfall_prob|number_format(0) }}%</strong>
                                            {% if day.rain_intensity_label %}
                                                <span class="text-body-secondary">
                                                    ({{ day.rain_intensity_label|trans|lower }})
                                                </span>
                                            {% endif %}
                                        </li>
                                        <li>
                                            <i class="bi bi-wind me-1 text-secondary" aria-hidden="true"></i>
                                            {{ 'location.wind'|trans }}:
                                            <strong>{{ day.wind_dir }}</strong>
                                            <span class="text-body-secondary">
                                                · {{ day.wind_speed_label|trans }}
                                            </span>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <div class="d-flex flex-wrap align-items-baseline justify-content-between mb-3 mt-4 gap-2">
            <h2 class="h4 mb-0">
                <i class="bi bi-stars me-2 text-warning" aria-hidden="true"></i>{{ 'location.astronomical_section'|trans }}
            </h2>
        </div>

        <div class="row g-3 mt-2">
            {# ── Solar times card ─────────────────────────────────────────── #}
            <div class="col-12 col-lg-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h2 class="h6 mb-0">
                            <i class="bi bi-sun-fill text-warning me-2" aria-hidden="true"></i>{{ 'location.sun_section'|trans }}
                            {% if day_length_minutes %}
                                <span class="fw-normal text-body-secondary ms-2 small">
                                    · {{ 'location.day_length'|trans }}: {{ (day_length_minutes // 60) }}h {{ (day_length_minutes % 60) }}min
                                </span>
                            {% endif %}
                        </h2>
                    </div>
                    <div class="card-body p-0">
                        <dl class="row g-0 mb-0 px-3 pt-3 small">
                            {%- set sun_rows = [
                                ['bi-brightness-alt-high',    'night_end',       night_end],
                                ['bi-cloud-sun',              'nautical_dawn',   nautical_dawn],
                                ['bi-sunrise',                'dawn',            dawn],
                                ['bi-brightness-high',        'golden_hour_end', golden_hour_end],
                                ['bi-sunrise-fill',           'sunrise',         sunrise],
                                ['bi-sun',                    'sunrise_end',     sunrise_end],
                                ['bi-sun-fill',               'solar_noon',      solar_noon],
                                ['bi-sun',                    'sunset_start',    sunset_start],
                                ['bi-sunset-fill',            'sunset',          sunset],
                                ['bi-brightness-high',        'golden_hour',     golden_hour],
                                ['bi-sunset',                 'dusk',            dusk],
                                ['bi-cloud-moon',             'nautical_dusk',   nautical_dusk],
                                ['bi-moon-stars',             'night',           night],
                                ['bi-moon-fill',              'nadir',           nadir],
                            ] -%}
                            {% for row in sun_rows %}
                                <dt class="col-6 col-sm-7 col-md-7 col-lg-7 pb-2">
                                    <i class="bi {{ row[0] }} me-1 text-warning" aria-hidden="true"></i>{{ ('location.' ~ row[1])|trans }}
                                </dt>
                                <dd class="col-6 col-sm-5 col-md-5 col-lg-5 pb-2">
                                    {% if row[2] %}
                                        {{ row[2]|date('H:i', timezone) }}
                                        <span class="text-body-tertiary ms-1">({{ timezone }})</span>
                                    {% else %}
                                        <span class="text-body-secondary">—</span>
                                    {% endif %}
                                </dd>
                            {% endfor %}
                        </dl>
                        {% if sun_azimuth_deg is not null %}
                            <div class="border-top px-3 py-2 small text-body-secondary">
                                <i class="bi bi-compass me-1" aria-hidden="true"></i>
                                {{ 'location.sun_position'|trans }}:
                                {{ 'location.azimuth'|trans }} <strong>{{ sun_azimuth_deg }}°</strong>
                                <span class="mx-1">·</span>
                                {{ 'location.altitude'|trans }} <strong>{{ sun_altitude_deg }}°</strong>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# ── Moon card ────────────────────────────────────────────────── #}
            {% if moon_illumination %}
                {%- set moon_pct   = (moon_illumination.fraction * 100)|round -%}
                {%- set moon_phase = moon_illumination.phase|default(0) -%}
                {%- if moon_phase < 0.125 %}
                    {%- set moon_phase_key = 'moon_phase_new' -%}
                    {%- set moon_char = '🌑' -%}
                {%- elseif moon_phase < 0.25 %}
                    {%- set moon_phase_key = 'moon_phase_waxing_crescent' -%}
                    {%- set moon_char = '🌒' -%}
                {%- elseif moon_phase < 0.375 %}
                    {%- set moon_phase_key = 'moon_phase_first_quarter' -%}
                    {%- set moon_char = '🌓' -%}
                {%- elseif moon_phase < 0.5 %}
                    {%- set moon_phase_key = 'moon_phase_waxing_gibbous' -%}
                    {%- set moon_char = '🌔' -%}
                {%- elseif moon_phase < 0.625 %}
                    {%- set moon_phase_key = 'moon_phase_full' -%}
                    {%- set moon_char = '🌕' -%}
                {%- elseif moon_phase < 0.75 %}
                    {%- set moon_phase_key = 'moon_phase_waning_gibbous' -%}
                    {%- set moon_char = '🌖' -%}
                {%- elseif moon_phase < 0.875 %}
                    {%- set moon_phase_key = 'moon_phase_last_quarter' -%}
                    {%- set moon_char = '🌗' -%}
                {%- else %}
                    {%- set moon_phase_key = 'moon_phase_waning_crescent' -%}
                    {%- set moon_char = '🌘' -%}
                {%- endif %}
                <div class="col-12 col-lg-5">
                    <div class="card shadow-sm h-100">
                        <div class="card-header">
                            <h2 class="h6 mb-0">
                                <i class="bi bi-moon-stars-fill text-secondary me-2" aria-hidden="true"></i>{{ 'location.moon_section'|trans }}
                            </h2>
                        </div>
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center gap-2 py-4">
                            <span class="display-1" aria-hidden="true">{{ moon_char }}</span>
                            <div class="fw-semibold fs-5">{{ ('location.' ~ moon_phase_key)|trans }}</div>
                            <dl class="row text-start w-100 mb-0 small mt-2">
                                {% if moonrise %}
                                    <dt class="col-6 col-sm-6 col-md-6 col-lg-5 pb-2">{{ 'location.moonrise'|trans }}</dt>
                                    <dd class="col-6 col-sm-6 col-md-6 col-lg-7 pb-2">{{ moonrise|date('H:i', timezone) }} <span class="text-body-tertiary">({{ timezone }})</span></dd>
                                {% endif %}
                                {% if moonset %}
                                    <dt class="col-6 col-sm-6 col-md-6 col-lg-5 pb-2">{{ 'location.moonset'|trans }}</dt>
                                    <dd class="col-6 col-sm-6 col-md-6 col-lg-7 pb-2">{{ moonset|date('H:i', timezone) }} <span class="text-body-tertiary">({{ timezone }})</span></dd>
                                {% endif %}
                                <dt class="col-6 col-sm-6 col-md-6 col-lg-5 pb-2">{{ 'location.moon_illumination'|trans }}</dt>
                                <dd class="col-6 col-sm-6 col-md-6 col-lg-7 pb-2">{{ moon_pct }}%</dd>
                                <dt class="col-6 col-sm-6 col-md-6 col-lg-5 pb-2">{{ 'location.moon_phase'|trans }}</dt>
                                <dd class="col-6 col-sm-6 col-md-6 col-lg-7 pb-2">{{ moon_illumination.phase|number_format(3) }}</dd>
                                {% if moon_distance_km %}
                                    <dt class="col-6 col-sm-6 col-md-6 col-lg-5 pb-2">{{ 'location.moon_distance'|trans }}</dt>
                                    <dd class="col-6 col-sm-6 col-md-6 col-lg-7 pb-2">{{ moon_distance_km|number_format(0) }} km</dd>
                                {% endif %}
                            </dl>
                        </div>
                        {% if moon_azimuth_deg is not null %}
                            <div class="border-top px-3 py-2 small text-body-secondary">
                                <i class="bi bi-compass me-1" aria-hidden="true"></i>
                                {{ 'location.moon_position'|trans }}:
                                {{ 'location.azimuth'|trans }} <strong>{{ moon_azimuth_deg }}°</strong>
                                <span class="mx-1">·</span>
                                {{ 'location.altitude'|trans }} <strong>{{ moon_altitude_deg }}°</strong>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
